{
  "manifest_version": 3,
  "name": "LinkGuard",
  "version": "0.4.0",
  "description": "Link safety scanner — scans links on click using VirusTotal, URLhaus, OpenPhish, ThreatFox, and a community blocklist.",
  "permissions": ["storage", "scripting", "tabs", "webNavigation", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "https://www.virustotal.com/*",
    "https://urlhaus.abuse.ch/*",
    "https://openphish.com/*",
    "https://threatfox-api.abuse.ch/*",
    "https://*.hf.space/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkGuard",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
